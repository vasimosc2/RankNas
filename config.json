{
    "model_search_space":{
        "stem_block":{
            "filters": [32, 64, 128],
            "Conv_kernel": [3, 5],
            "Conv_strides": [2, 3],
            "DWConv_kernel": [3, 5],
            "DWConv_strides": [1, 2]
        },
        "stages_block":{
            "stages_number": [3,4,5,6],
            "taku_block": {
                "taku_block_number": [4,5,6],
