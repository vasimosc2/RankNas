                "DWConv_strides": [1]
            },
            "downsampler":{
                "pool_size": [2],
                "Conv_kernel": [1,3,5],
                "strides": [1, 2]
            }
        },
        "refiner_block":{
            "DWConv_kernel": [3,5],
            "DWConv_strides": [1, 2],
            "num_output_classes": 100
        },
        "optimizer": ["sgd","adamw"]
